# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=welve
MONGO_APP_USER=welve_app
MONGO_APP_PASSWORD=changeme_app
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=changeme_root

# URI construida para el backend (usa usuario de aplicación, no root).
# NUNCA pongas la URI real acá — este archivo se commitea. La real va en
# .env (local, gitignored) o en .env.production / las variables de Railway.
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/?appName=welve
# ── Redis / Celery ────────────────────────────────────────────────────────────
# Local (docker compose up redis -d): redis://redis:6379/0 (dentro de la red
# de compose) o redis://localhost:6379/0 (backend nativo, ver CLAUDE.md).
# Producción (Railway Redis o Upstash): usa la URL que te den, típicamente
# rediss:// (con doble s, TLS) en vez de redis://.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Backend / FastAPI ─────────────────────────────────────────────────────────
# En producción: genera uno nuevo con
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# y nunca reutilices el de desarrollo.
SECRET_KEY=super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENVIRONMENT=development
# Lista separada por comas de orígenes exactos permitidos (además del regex
# de Railway/Codespaces ya configurado en app/main.py para subdominios).
CORS_ORIGINS=http://localhost:5173,http://localhost:80
FRONTEND_URL=http://localhost:5173

# ── Frontend ──────────────────────────────────────────────────────────────────
# Se usa en build time (Vite lo incrusta en el bundle estático — ver
# vite.config.ts y src/api/client.ts), no en runtime. En producción es la URL
# pública del backend, ej. https://welve-backend.up.railway.app
VITE_API_URL=http://localhost:8000
